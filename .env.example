NODE_ENV=development
PORT=8980
APP_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176

# Existing .NET backend integration
DOTNET_API_BASE_URL=http://localhost:5000/api
DOTNET_AUTH_ME_PATH=/auth/me
DOTNET_TASKS_PATH=/tasks
DOTNET_EVENTS_PATH=/events
DOTNET_NOTES_PATH=/notes
DOTNET_WORKLOGS_PATH=/worklogs

# Optional: if .NET and this service share JWT secret, token can be verified locally.
# If empty, this service validates token by calling DOTNET_AUTH_ME_PATH.
JWT_SHARED_SECRET=

# AI and speech providers
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
DEEPGRAM_API_KEY=
DEEPGRAM_STT_MODEL=nova-3
DEEPGRAM_TTS_MODEL=aura-2-thalia-en
